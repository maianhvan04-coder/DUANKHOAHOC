# Server
NODE_ENV=development
PORT=8080
CORS_ORIGIN=http://localhost:3000

# Public URLs
# PUBLIC_API_URL must be reachable by VNPAY for the return URL.
PUBLIC_API_URL=http://localhost:8080
FRONTEND_URL=http://localhost:3000
APP_URL=http://localhost:3000

# Database
MONGODB_URI=mongodb://127.0.0.1:27017/everest
# The RBAC seed script also accepts MONGO_DB_URL or MONGO_URI.
MONGO_DB_URL=mongodb://127.0.0.1:27017/everest
MONGO_URI=mongodb://127.0.0.1:27017/everest

# JWT
JWT_ACCESS_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_EXPIRES=15m
JWT_ACCESS_EXPIRES_MS=900000
JWT_REFRESH_DAYS=7

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# VNPAY
VNPAY_TMN_CODE=your-vnpay-tmn-code
VNPAY_HASH_SECRET=your-vnpay-hash-secret
VNPAY_PAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html

# Gemini / Google AI
# Use either GEMINI_API_KEY or a comma-separated GEMINI_API_KEYS list.
GEMINI_API_KEY=your-gemini-api-key
GEMINI_API_KEYS=
GOOGLE_AI_API_KEY=
GOOGLE_AI_API_KEYS=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_FALLBACK_MODELS=gemini-2.5-flash
